# ==============================
# GEMINI
# ==============================

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash


# ==============================
# NVIDIA NIM
# ==============================

NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct


# =========================
# Provider Routing
# =========================

DEFAULT_PROVIDER=gemini
CODE_PROVIDER=nim
ARCHITECTURE_PROVIDER=nim

# Provider específico para documentación (README, etc.)
DOCUMENTATION_PROVIDER=nim
FALLBACK_PROVIDERS=nim,gemini


# ==============================
# Timeouts
# ==============================

# Tiempo máximo para comandos de Shell (segundos)
SHELL_TIMEOUT=180

# Tiempo máximo para comandos de Docker (segundos)
DOCKER_TIMEOUT=120

LARAVEL_TIMEOUT=900

# ==============================
# OBSIDIAN
# ==============================

OBSIDIAN_VAULT_PATH=~/Workspace/Obsidian

# ==============================
# DASHBOARD
# ==============================
DASHBOARD_API_KEY=tu_clave_super_secreta_aqui
DASHBOARD_DEBUG=false
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5000