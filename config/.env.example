# ================== AIClient - Configuración Fase 1 ==================

# Google Gemini API (obténla en https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=tu_clave_gemini_aqui

# NVIDIA NIM (opcional por ahora)
NIM_API_KEY=tu_clave_nim_aqui
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Ruta a tu vault de Obsidian
OBSIDIAN_VAULT_PATH=~/Workspace/Obsidian
