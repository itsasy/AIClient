{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "AI Assistant (Consultar)",
            "type": "shell",
            "command": "ai",
            "args": ["${input:prompt}"],
            "group": "none",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": []
        },
        {
            "label": "AI Assistant (Chat Interactivo)",
            "type": "shell",
            "command": "ai",
            "args": ["--chat"],
            "group": "none",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "prompt",
            "type": "promptString",
            "description": "Escribe tu consulta para el asistente"
        }
    ]
}